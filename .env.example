# 管理后台登录密码（必填，生产环境务必修改）
ADMIN_PASSWORD=admin123

# 用户数据持久化：Vercel Blob（必填则持久化，不填则仅内存、重启清空）
# 在 Vercel 项目 Storage 中创建 Blob Store 后会自动生成，本地用 vercel env pull 拉取
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# 管理员 Token 签名密钥（可选，默认与 ADMIN_PASSWORD 一致）
# ADMIN_SECRET=your-random-secret

# 用户 Token 签名密钥（可选，用于后续 /api/auth/login、/api/ping 等）
# USER_JWT_SECRET=your-user-secret
